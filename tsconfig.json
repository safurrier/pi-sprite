{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["extensions/**/*.ts", "tests/**/*.ts"],
	"exclude": ["node_modules"]
}
